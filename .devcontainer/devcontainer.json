{
  "name": "Learning Lab (Node 20 + pnpm)",
  "image": "mcr.microsoft.com/devcontainers/javascript-node:20",
  "postCreateCommand": "node scripts/codespaces-ensure-ready.js",
  "postStartCommand": "node scripts/codespaces-ensure-ready.js",
  "forwardPorts": [3001, 3002],
  "portsAttributes": {
    "3001": { "label": "Issuer" },
    "3002": { "label": "Verifier" }
  }
}
